{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycel.local/schemas/head-inspect.schema.json",
  "title": "Mycel Head Inspect Input Bundle",
  "description": "Local input bundle for the minimal mycel head inspect CLI.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "description",
    "revisions",
    "views"
  ],
  "oneOf": [
    {
      "required": ["profile"],
      "not": {
        "required": ["profiles"]
      }
    },
    {
      "required": ["profiles"],
      "not": {
        "required": ["profile"]
      }
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "$ref": "#/$defs/profile"
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    },
    "revisions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "views": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "viewer_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/viewer_signal"
      }
    },
    "critical_violations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/critical_violation"
      }
    },
    "expected": {
      "$ref": "#/$defs/expected"
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_hash",
        "effective_selection_time",
        "epoch_seconds",
        "epoch_zero_timestamp",
        "admission_window_epochs",
        "min_valid_views_for_admission",
        "min_valid_views_per_epoch",
        "weight_cap_per_key"
      ],
      "properties": {
        "policy_hash": {
          "type": "string",
          "minLength": 1
        },
        "effective_selection_time": {
          "type": "integer",
          "minimum": 0
        },
        "epoch_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "epoch_zero_timestamp": {
          "type": "integer"
        },
        "admission_window_epochs": {
          "type": "integer",
          "minimum": 0
        },
        "min_valid_views_for_admission": {
          "type": "integer",
          "minimum": 0
        },
        "min_valid_views_per_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "weight_cap_per_key": {
          "type": "integer",
          "minimum": 1
        },
        "viewer_score": {
          "$ref": "#/$defs/viewer_score"
        }
      }
    },
    "viewer_score": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "disabled",
            "bounded-bonus-penalty"
          ]
        },
        "bonus_cap": {
          "type": "integer",
          "minimum": 0
        },
        "penalty_cap": {
          "type": "integer",
          "minimum": 0
        },
        "signal_weight_cap": {
          "type": "integer",
          "minimum": 0
        },
        "admission_required": {
          "type": "boolean"
        },
        "min_identity_tier": {
          "type": "string",
          "enum": [
            "none",
            "basic",
            "strong"
          ]
        },
        "min_reputation_band": {
          "type": "string",
          "enum": [
            "new",
            "established",
            "trusted"
          ]
        }
      }
    },
    "viewer_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "viewer_id",
        "candidate_revision_id",
        "signal_type",
        "confidence_level",
        "created_at",
        "expires_at"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "viewer_id": {
          "type": "string",
          "minLength": 1
        },
        "candidate_revision_id": {
          "type": "string",
          "minLength": 1
        },
        "signal_type": {
          "type": "string",
          "enum": [
            "approval",
            "objection",
            "challenge"
          ]
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "confidence_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "integer",
          "minimum": 0
        },
        "expires_at": {
          "type": "integer",
          "minimum": 0
        },
        "signal_status": {
          "type": "string",
          "enum": [
            "active",
            "expired",
            "withdrawn",
            "resolved"
          ]
        },
        "viewer_identity_tier": {
          "type": "string",
          "enum": [
            "none",
            "basic",
            "strong"
          ]
        },
        "viewer_admission_status": {
          "type": "string",
          "enum": [
            "pending",
            "admitted",
            "restricted",
            "revoked"
          ]
        },
        "viewer_reputation_band": {
          "type": "string",
          "enum": [
            "new",
            "established",
            "trusted"
          ]
        }
      }
    },
    "critical_violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maintainer",
        "timestamp"
      ],
      "properties": {
        "maintainer": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "doc_id",
        "selected_head"
      ],
      "properties": {
        "doc_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_head": {
          "type": "string",
          "minLength": 1
        },
        "eligible_head_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_revision_count": {
          "type": "integer",
          "minimum": 0
        },
        "verified_view_count": {
          "type": "integer",
          "minimum": 0
        },
        "viewer_signal_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
