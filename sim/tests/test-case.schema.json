{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycel.local/schemas/test-case.schema.json",
  "title": "Mycel Peer Simulator Test Case",
  "description": "Language-neutral contract for one simulator test definition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "test_id",
    "description",
    "category",
    "topology",
    "fixture_set",
    "execution_mode",
    "expected_result"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "test_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "positive",
        "negative",
        "recovery",
        "deterministic-comparison"
      ]
    },
    "topology": {
      "type": "string",
      "minLength": 1
    },
    "fixture_set": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "single-process",
        "multi-process"
      ]
    },
    "expected_result": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assertion"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "description"
      ],
      "properties": {
        "assertion_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "expected": {
          "type": "string"
        }
      }
    }
  }
}
