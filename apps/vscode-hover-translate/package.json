{
  "name": "mycel-hover-translate",
  "displayName": "Mycel Hover Translate",
  "description": "Translate selected text and show the result in a hover popup when the cursor rests on the selection.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctf2090/Mycel.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:hoverTranslate.clearCache"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hoverTranslate.clearCache",
        "title": "Hover Translate: Clear Cache"
      },
      {
        "command": "hoverTranslate.translateSelectionOrClipboard",
        "title": "Hover Translate: Translate Selection or Clipboard"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "hoverTranslate.translateSelectionOrClipboard",
          "when": "editorHasSelection",
          "group": "navigation@99"
        }
      ],
      "webview/context": [
        {
          "command": "hoverTranslate.translateSelectionOrClipboard",
          "group": "navigation@99"
        }
      ]
    },
    "configuration": {
      "title": "Hover Translate",
      "properties": {
        "hoverTranslate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable hover translation for selected text."
        },
        "hoverTranslate.targetLanguage": {
          "type": "string",
          "default": "zh-TW",
          "description": "Target language code used for translation."
        },
        "hoverTranslate.sourceLanguage": {
          "type": "string",
          "default": "auto",
          "description": "Source language code. Use 'auto' to detect automatically."
        },
        "hoverTranslate.maxSelectionLength": {
          "type": "number",
          "default": 240,
          "minimum": 1,
          "description": "Maximum selected text length that will trigger hover translation."
        },
        "hoverTranslate.showOriginalText": {
          "type": "boolean",
          "default": true,
          "description": "Show the selected source text inside the hover popup."
        },
        "hoverTranslate.provider": {
          "type": "string",
          "enum": [
            "google-web"
          ],
          "default": "google-web",
          "description": "Translation provider used by the extension."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.8.3"
  }
}
